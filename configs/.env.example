# configs/.env.example
# COPIAR para /opt/vps-agent/.env e preencher com suas credenciais reais
# NUNCA commitar o .env com valores reais — este arquivo é apenas o template

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=vps_agent
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=vps_agent

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Obter token em: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=SEU_BOT_TOKEN_AQUI
# IDs numéricos dos usuários autorizados (separados por vírgula)
TELEGRAM_ALLOWED_USERS=SEU_USER_ID_AQUI

# ─── OpenRouter (LLM) ─────────────────────────────────────────────────────────
# Obter em: https://openrouter.ai/keys
OPENROUTER_API_KEY=SUA_CHAVE_OPENROUTER_AQUI
OPENROUTER_MODEL=minimax/minimax-m2.5
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_TIMEOUT=30

# ─── Qdrant (Memória Semântica — opcional, sob demanda) ───────────────────────
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=5
QDRANT_SEMANTIC_ENABLED=true
QDRANT_SEMANTIC_COLLECTION=agent_semantic_memory
QDRANT_SEMANTIC_VECTOR_SIZE=64
QDRANT_SEMANTIC_RECALL_LIMIT=3

# ─── MCP Server ───────────────────────────────────────────────────────────────
MCP_HOST=127.0.0.1
MCP_PORT=8765
# Opcional, mas recomendado para acesso remoto/proxy
MCP_API_KEY=TROQUE_POR_UMA_CHAVE_FORTE

# ─── Gateway HTTP (opcional) ─────────────────────────────────────────────────
GATEWAY_API_KEY=TROQUE_POR_UMA_CHAVE_FORTE
GATEWAY_ALLOWED_ORIGINS=http://localhost,https://localhost

# ─── FleetIntel MCP — Dados de frota de veículos pesados do Brasil ───────────
# MCP server exposto via Cloudflare Tunnel (não expõe IP do host)
FLEETINTEL_MCP_URL=https://mcp.gtaitson.space/mcp
FLEETINTEL_MCP_TOKEN=SEU_TOKEN_FLEETINTEL_AQUI

# ─── BrazilCNPJ MCP — Enriquecimento cadastral e societario ─────────────────
BRAZILCNPJ_MCP_URL=https://cnpj-mcp.gtaitson.space/mcp
BRAZILCNPJ_MCP_TOKEN=SEU_TOKEN_BRAZILCNPJ_AQUI

# ——— Orquestração Runtime (Fase 1) ————————————————————————————————————————————————————————
# Local skills continuam padrão. Ative protocolos externos apenas quando disponíveis.
ORCH_ENABLE_MCP=false
ORCH_MCP_BASE_URL=http://127.0.0.1:8765
ORCH_MCP_API_KEY=

ORCH_ENABLE_A2A=false
ORCH_A2A_ENDPOINT=

ORCH_ENABLE_ACP=false
ORCH_ACP_ENDPOINT=

ORCH_ENABLE_DEEPAGENTS=false
ORCH_DEEPAGENTS_ENDPOINT=

ORCH_ENABLE_OPENCLAW=false
ORCH_OPENCLAW_ENDPOINT=
ORCH_OPENCLAW_API_KEY=

ORCH_TIMEOUT_SECONDS=30

# ——— Alma / Identidade (Fase 1) ————————————————————————————————————————————————
SOUL_OWNER_NAME=Guilherme
SOUL_CHALLENGE_MODE_ENABLED=true

# ——— Catálogo de Skills Externos (Fase 1) ————————————————————————————————
CATALOG_ENABLED=true
CATALOG_SOURCES_FILE=configs/skills-catalog-sources.json
# Snapshot padrao: skill pack do repositorio Guitaitson/fleetintel-mcp
CATALOG_FALLBACK_CACHE_FILE=configs/skills-catalog-cache.json
CATALOG_HISTORY_FILE=configs/skills-catalog-history.json
CATALOG_PINS_FILE=configs/skills-catalog-pins.json
CATALOG_GITHUB_TOKEN=
CATALOG_CHECK_INTERVAL_SECONDS=21600
CATALOG_HTTP_TIMEOUT_SECONDS=20
CATALOG_APPROVAL_REQUIRED_FOR_APPLY=true
